# ── APP ──
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5174

# ── DATABASE ──
DATABASE_URL="mysql://root:SENHA@localhost:3306/voogo_db"

# ── SEGURANÇA ──
